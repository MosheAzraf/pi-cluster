{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabledManagers": ["argocd", "kubernetes"],
  "prHourlyLimit": 10,
  "argocd": {
    "managerFilePatterns": ["/kubernetes/_argocd/.+\\.ya?ml$/"]
  },
  "kubernetes": {
    "fileMatch": [
      "kubernetes/apps/.+\\.ya?ml$",
      "kubernetes/infrastructure/.+\\.ya?ml$",
      "kubernetes/monitoring/.+\\.ya?ml$"
    ]
  }
}